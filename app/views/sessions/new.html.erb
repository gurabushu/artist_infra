<%= render "shared/site_header", title: "Creator Link" %>

<h1 class="session-title">ログイン</h1>

<div class="session-form">
<%= form_with url: login_path, method: :post, local: true do |f| %>
  <div class="form-group">
    <label>メールアドレス</label><br>
    <%= email_field_tag :email %>
  </div>

  <div class="form-group">
    <label>パスワード</label><br>
    <%= password_field_tag :password %>
  </div>

  <div class="form-group">
    <%= submit_tag "ログイン" %>
  </div>
  <%end %>
</div>


<div class="cta">
  <% if logged_in? %>
    <%= link_to "ユーザー一覧", users_path, class: "button" %>
  <% else %>
    <%= link_to "戻る", root_path, class: "button" %>
    <%= link_to "新規登録", new_user_path, class: "button secondary" %>
  <% end %>
</div>


